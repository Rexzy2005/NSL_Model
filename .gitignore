# ══════════════════════════════════════════════════════════════════════════════
# NSL Translator — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.ENV/
env.bak/
venv.bak/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Jupyter notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json
credentials.json
service-account*.json

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd/
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ══════════════════════════════════════════════════════════════════════════════
#  DATASET
#  The dataset is large binary data — store outside git.
#  Use DVC, Google Drive, or a separate data repo instead.
# ══════════════════════════════════════════════════════════════════════════════

# downloaded YouTube videos
dataset/downloads/*
!dataset/downloads/.gitkeep

# raw MediaPipe landmark sequences (.npy)
dataset/raw/
!dataset/raw/.gitkeep

# MediaPipe model downloads (~20 MB)
dataset/.mp_models/

# final processed arrays
dataset/processed/
!dataset/processed/.gitkeep

# train / val / test splits
dataset/splits/
!dataset/splits/.gitkeep

# extraction resume fingerprint
dataset/.extracted_done.json

# ══════════════════════════════════════════════════════════════════════════════
#  MODELS
#  Trained .h5 and .tflite are git-ignored.
#  Keep only small architecture / config files in git.
# ══════════════════════════════════════════════════════════════════════════════

# Keras checkpoints and saved models
model/checkpoints/*.h5
model/checkpoints/*.keras
model/saved_model/
!model/saved_model/.gitkeep

# TFLite exports
model/tflite/*.tflite
!model/tflite/.gitkeep

# TensorFlow Lite cache
model/.tflite_cache/

# logs and tensorboard
logs/
*.log
tensorboard_logs/
runs/

# ══════════════════════════════════════════════════════════════════════════════
#  EVALUATION
#  Generated charts and reports — regenerated on every run
# ══════════════════════════════════════════════════════════════════════════════

evaluation/results/*.png
evaluation/results/*.txt
evaluation/benchmarks/*.txt
!evaluation/results/.gitkeep
!evaluation/benchmarks/.gitkeep

# ══════════════════════════════════════════════════════════════════════════════
#  FLUTTER APP
#  Generated files and downloaded model assets
# ══════════════════════════════════════════════════════════════════════════════

flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
flutter_app/.packages
flutter_app/.pub-cache/
flutter_app/.pub/
flutter_app/build/
flutter_app/.idea/
flutter_app/*.iml
flutter_app/.metadata

# downloaded TFLite model in assets
flutter_app/assets/models/*.tflite
!flutter_app/assets/models/.gitkeep

# Android build artefacts
flutter_app/android/.gradle/
flutter_app/android/captures/
flutter_app/android/gradlew
flutter_app/android/gradlew.bat
flutter_app/android/local.properties
flutter_app/android/**/GeneratedPluginRegistrant.java
flutter_app/android/key.properties

# iOS build artefacts
flutter_app/ios/Pods/
flutter_app/ios/.symlinks/
flutter_app/ios/Flutter/Flutter.framework
flutter_app/ios/Flutter/Flutter.podspec
flutter_app/ios/Flutter/flutter_export_environment.sh
flutter_app/ios/Runner.xcworkspace/xcuserdata/
flutter_app/ios/Runner.xcodeproj/project.xcworkspace/xcuserdata/
flutter_app/ios/Runner.xcodeproj/xcuserdata/
flutter_app/ios/Runner.xcworkspace/xcuserdata/